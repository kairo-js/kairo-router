{
    "name": "@kairo-js/router",
    "version": "0.1.1",
    "description": "Router module for Kairo.js",
    "type": "module",
    "license": "MIT",
    "packageManager": "pnpm@10.31.0",
    "sideEffects": false,
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "import": "./lib/index.js",
            "types": "./lib/index.d.ts"
        }
    },
    "files": [
        "lib"
    ],
    "repository": {
        "type": "git",
        "url": "git@github.com:kairo-js/kairo-router.git"
    },
    "scripts": {
