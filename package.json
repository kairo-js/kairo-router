{
    "name": "@kairo-js/router",
    "version": "0.2.0-beta.27",
    "description": "Router module for Kairo.js",
    "type": "module",
    "license": "MIT",
    "packageManager": "pnpm@11.1.1",
    "sideEffects": false,
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "import": "./lib/index.js",
            "types": "./lib/index.d.ts"
        }
    },
    "files": [
        "lib"
    ],
    "repository": {
        "type": "git",
        "url": "git@github.com:kairo-js/kairo-router.git"
    },
    "scripts": {
        "clean": "tsup --clean",
        "build": "tsup",
        "postbuild": "node .build/postprocess-dts.js",
        "release": "pnpm run build && npm publish --tag beta"
    },
    "peerDependencies": {
        "@minecraft/server": "^2.7.0",
        "@minecraft/server-ui": "^2.0.0"
    },
    "devDependencies": {
        "@minecraft/server": "^2.7.0",
        "@minecraft/server-ui": "^2.0.0",
        "@types/seedrandom": "^3.0.8",
        "prettier": "^3.8.1",
        "ts-morph": "^28.0.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@kairo-js/properties": "1.2.1",
        "@kairo-js/utils": "1.2.1",
        "@sinclair/typebox": "^0.34.49",
        "fast-json-stringify": "^6.3.0",
        "seedrandom": "^3.0.5"
    }
}
