        "build": "tsup",
        "version:patch": "pnpm version patch",
        "prepublishOnly": "pnpm run version:patch && pnpm run build"
    },
    "peerDependencies": {
        "@minecraft/server": "^2.5.0",
        "@minecraft/server-ui": "^2.0.0"
    },
    "devDependencies": {
        "@minecraft/server": "^2.5.0",
        "@minecraft/server-ui": "^2.0.0",
        "prettier": "^3.8.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    }
